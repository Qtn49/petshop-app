# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# OpenAI (for invoice parsing)
OPENAI_API_KEY=your_openai_api_key

# Square OAuth
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_APPLICATION_SECRET=your_square_application_secret
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox
SQUARE_REDIRECT_URI=http://localhost:3000/api/square/callback

# For production, use your Vercel URL:
# SQUARE_REDIRECT_URI=https://your-app.vercel.app/api/square/callback
