# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Invoice parsing: regex is tried first (no key needed). AI fallback uses one of:
# OPENAI_API_KEY=your_openai_api_key
# GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key


# Square OAuth (Settings > Connect Square). Register redirect URI in Square Developer Dashboard.
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_APPLICATION_SECRET=your_square_application_secret
# Must match the redirect URL in Square Dashboard OAuth settings
SQUARE_REDIRECT_URI=http://localhost:3000/api/square/callback

# For production:
# SQUARE_REDIRECT_URI=https://your-app.vercel.app/api/square/callback
