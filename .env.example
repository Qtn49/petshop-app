# Auth (required): HS256 JWT for ps_device_ / ps_session_ cookies — min 32 characters
JWT_SECRET=generate-a-random-32-char-string-here

# Optional: shown on /register “Contact us” mailto
# NEXT_PUBLIC_CONTACT_EMAIL=you@gmail.com

# Supabase (SUPABASE_SERVICE_ROLE_KEY required for Square OAuth so connection is saved and persists)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Invoice parsing: regex is tried first (no key needed). AI fallback uses one of:
# OPENAI_API_KEY=your_openai_api_key
# GROQ_API_KEY=your_groq_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key


# Square OAuth (Settings > Connect Square). Register redirect URI in Square Developer Dashboard.
SQUARE_APPLICATION_ID=your_square_application_id
SQUARE_APPLICATION_SECRET=your_square_application_secret
# Must match EXACTLY the URL in Square Dashboard (no trailing slash). If you get "Invalid value for parameter redirect_uri", copy the value from GET /api/square/redirect-uri into Square.
SQUARE_REDIRECT_URI=http://localhost:3000/api/square/callback
# For ngrok use: https://YOUR-NGROK-HOST.ngrok-free.app/api/square/callback (add the same in Square Dashboard)

